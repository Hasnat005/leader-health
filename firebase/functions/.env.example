# firebase/functions — local emulator only
# Copy to `.env` (gitignored). Production uses Google Secret Manager.

STRIPE_SECRET_KEY=
GEN_HEALTH_API_KEY=
GEN_HEALTH_PUBLIC_API_BASE_URL=https://api.gen-health.app
POSTMARK_SERVER_TOKEN=

# Enable paid consult orders on checkout confirm (recommended for production)
GEN_HEALTH_REQUEST_CONSULT_API_ORDERS_ENABLED=true

# Optional attribution without promo code
# ATTRIBUTION_ALLOW_NO_PROMO_UTM=true

# Framer / live site URL (funnel emails if enabled later)
STOREFRONT_BASE_URL=https://www.myleaderhealth.com

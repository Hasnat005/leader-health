rules_version = '2';

/**
 * Leader Health storefront — all reads/writes via Cloud Functions Admin SDK.
 * Framer and browsers must use catalogHttp, checkoutHttp, etc. (not Firestore SDK).
 */
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
